# ─────────────────────────────────────────────────────────
#  Polar School API — variables de entorno
#  Copiar este archivo a .env y completar.
#  NUNCA commitear .env.
# ─────────────────────────────────────────────────────────

# Postgres (docker compose dev o prod)
DATABASE_URL=postgres://polar:CHANGE_ME@127.0.0.1:5433/polar_school

# Server
PORT=3001
NODE_ENV=development

# CORS: dominios separados por coma
CORS_ORIGIN=http://127.0.0.1:3000,http://localhost:3000

# Magic link: URL base del frontend para armar el enlace.
# En dev: http://127.0.0.1:3000
# En staging: https://staging.polar.school
# En prod: https://polar.school
PUBLIC_WEB_URL=http://127.0.0.1:3000

# Resend (sólo producción, opcional en dev → muestra el link en consola).
# Crear cuenta gratuita en https://resend.com
RESEND_API_KEY=
RESEND_FROM=noreply@polar.school
