    "lucia": "^3.2.2",
    "oslo": "^1.2.1",
    "postgres": "^3.4.5",
    "resend": "^4.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.28.1",
