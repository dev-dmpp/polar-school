---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import { primerSitioWeb } from '@polar-school/content'
import { LessonRenderer, MarkComplete } from '@polar-school/ui'

export function getStaticPaths() {
  return primerSitioWeb.lessons.map((lesson) => ({
    params: { slug: lesson.slug },
    props: { lesson },
  }))
}

const { lesson } = Astro.props
const idx = primerSitioWeb.lessons.findIndex((l) => l.slug === lesson.slug)
const prev = idx > 0 ? primerSitioWeb.lessons[idx - 1] : null
const next = idx < primerSitioWeb.lessons.length - 1 ? primerSitioWeb.lessons[idx + 1] : null
---

<BaseLayout title={`${lesson.title} — ${primerSitioWeb.meta.title}`}>
  <article class="lesson">
    <header>
      <a href="/cursos/primer-sitio-web" class="back">← {primerSitioWeb.meta.title}</a>
      <span class="tag">{lesson.category} · {lesson.difficulty}</span>
      <h1>{lesson.title}</h1>
      <p class="lead">{lesson.description}</p>
      <p class="meta">Lección {idx + 1} de {primerSitioWeb.lessons.length} · ~{lesson.readTime} min de lectura</p>
    </header>

    <section class="block">
      <h2>Prueba esto</h2>
      <div class="tryit-block">
        <p class="tryit-hint">
          Editá el HTML, CSS y JS en los paneles. El preview al lado se actualiza
          solo al escribir. Probá cambiar el color del título o el mensaje del botón.
        </p>
        <LessonRenderer
          client:load
          kind={lesson.kind}
          slug={lesson.slug}
          title={lesson.title}
          height="420px"
        />
      </div>
    </section>

    {lesson.example && (
      <section class="block">
        <h2>Ejemplo real</h2>
        <pre class="code"><code>{lesson.example}</code></pre>
      </section>
    )}

    {lesson.tip && (
      <section class="block">
        <div class="tip-block">
          <h2>Consejo</h2>
          <p>{lesson.tip}</p>
        </div>
      </section>
    )}

        <MarkComplete client:load courseSlug="primer-sitio-web" lessonSlug={lesson.slug} />

<nav class="lesson-nav">
      {prev ? (
        <a href={`/cursos/primer-sitio-web/${prev.slug}`} class="prev">← {prev.title}</a>
      ) : <span></span>}
      {next ? (
        <a href={`/cursos/primer-sitio-web/${next.slug}`} class="next">{next.title} →</a>
      ) : <span class="done">🎉 Última lección</span>}
    </nav>
  </article>
</BaseLayout>

<style>
  .lesson { max-width: 760px; margin: 0 auto; }
  .lesson header { margin-bottom: 2rem; }
  .back { display: inline-block; font-family: var(--font-hand); color: var(--accent-dark); text-decoration: none; margin-bottom: 0.5rem; font-size: 0.95rem; }
  .back:hover { text-decoration: underline; }
  .lesson h1 { font-size: 2.4rem; margin: 0.4rem 0 0.8rem; }
  .lead { font-size: 1.1rem; color: var(--ink-soft); }
  .block { margin: 2rem 0; }
  .block h2 { font-size: 1.5rem; color: var(--accent-dark); margin-bottom: 0.6rem; }
  .tryit-block { background: var(--paper-warm); border: 2px solid var(--wood); border-radius: 12px; padding: 1.5rem; }
  .tryit-hint { font-size: 0.9rem; color: var(--ink-soft); margin-bottom: 0.8rem; }
  .tryit-hint code { background: rgba(0,0,0,0.06); padding: 0.1em 0.4em; border-radius: 3px; font-family: var(--font-mono); }
  .code { background: #1a1a1a; color: #e0e0e0; padding: 1.2rem; border-radius: 8px; overflow-x: auto; font-family: var(--font-mono); font-size: 0.85rem; line-height: 1.5; }
  .tip-block { background: #fef3d7; border-left: 4px solid var(--accent); padding: 1rem 1.5rem; border-radius: 4px; }
  .tip-block h2 { color: var(--accent-dark); margin-top: 0; }
  .lesson-nav { display: flex; justify-content: space-between; gap: 1rem; margin-top: 3rem; padding-top: 2rem; border-top: 2px dashed var(--wood); }
  .lesson-nav a { text-decoration: none; color: var(--accent-dark); font-family: var(--font-hand); font-size: 1.05rem; font-weight: 700; padding: 0.5em 1em; border: 2px solid var(--wood); border-radius: 8px; transition: all 0.15s; }
  .lesson-nav a:hover { background: var(--wood); color: var(--paper); }
  .done { font-family: var(--font-hand); font-size: 1.05rem; color: var(--leaf-dark); padding: 0.5em 1em; }
</style>
