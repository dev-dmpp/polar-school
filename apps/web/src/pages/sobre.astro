    margin-top: 0.5rem;
  }
  .lead {
    font-size: 1.15rem;
    color: var(--ink-soft);
  }
  ul {
    color: var(--ink-soft);
    padding-left: 1.4rem;
  }
  ul li {
    margin: 0.5rem 0;
  }
  h2 {
    color: var(--accent-dark);
    margin-top: 2.5rem;
  }
</style>
