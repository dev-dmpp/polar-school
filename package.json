  "private": true,
  "description": "Plataforma educativa gratuita en español-latino sobre Linux, Docker, hosting y bases de datos.",
  "packageManager": "pnpm@10.34.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
